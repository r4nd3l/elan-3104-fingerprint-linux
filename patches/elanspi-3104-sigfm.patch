+  elanspi_smooth_image (img);
+  img->flags |= FPI_IMAGE_COLORS_INVERTED;
 
   /* submit image */
-  fpi_image_device_image_captured (FP_IMAGE_DEVICE (self), g_steal_pointer (&scaled));
