-  scaled = fpi_image_resize (img, 2, 2);
 
-  scaled->flags |= FPI_IMAGE_PARTIAL | FPI_IMAGE_COLORS_INVERTED;
+  /* The assembled image is used at native scale: its ~10px ridge period is
